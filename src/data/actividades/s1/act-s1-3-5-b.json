      "campos": [
        {
          "id": "agente_seguros",
          "label": "Nombre del Agente de Seguros",
          "type": "text",
          "placeholder": "Ej: Juan Pérez - Seguros Atlas...",
          "requerido": true
        },
        {
          "id": "abogado_familia",
          "label": "Contacto Legal",
          "type": "text",
          "placeholder": "Ej: Lic. García - Notaría 5...",
          "requerido": true
        }
      ]
    },
    {
      "id": "respaldo_documental",
      "titulo": "📂 Respaldo de Documentos",
      "descripcion": "¿Dónde guardas tus pólizas y contratos?",
      "campos": [
        {
          "id": "ubicacion_fisica",
          "label": "Ubicación de Originales (Ej: Caja fuerte)",
          "type": "text",
          "requerido": true
        },
        {
          "id": "respaldo_nube",
          "label": "¿Tienes copia digital en la nube?",
          "type": "select",
          "opciones": [
            "Sí, en carpeta protegida",
            "No, necesito hacerlo hoy"
          ],
          "requerido": true
        }
      ]
    },
    {
      "id": "protocolo_digital",
      "titulo": "🔑 Acceso Digital",
      "descripcion": "Si pierdes tu celular con el 2FA, ¿cómo entras a tus cuentas?",
      "campos": [
        {
          "id": "llaves_recuperacion",
          "label": "¿Sabes dónde están tus códigos de recuperación?",
          "type": "select",
          "opciones": [
            "Sí, en lugar seguro no digital",
            "No sé qué son"
          ],
          "requerido": true
        },
        {
          "id": "acceso_banco",
          "label": "Plan B para entrar al banco",
          "type": "textarea",
          "placeholder": "Ej: Tengo una tarjeta de coordenadas física en casa de mis padres...",
          "requerido": true
        }
      ]
    },
    {
      "id": "liquidez_inmediata",
      "titulo": "💰 Efectivo de Supervivencia",
      "descripcion": "Si los cajeros no funcionan por 3 días, ¿tienes efectivo?",
      "campos": [
        {
          "id": "monto_emergencia_72h",
          "label": "Monto guardado para 72 horas",
          "type": "slider",
          "min": 0,
          "max": 10000,
          "step": 500,
          "default": 2000,
          "unit": "$"
        },
        {
          "id": "meses_cobertura_emergencia",
          "label": "Meses de Gastos que Cubre",
          "type": "calculated",
          "formula": "Math.round(monto_emergencia_72h / 15000 * 10) / 10",
          "unit": " meses cubiertos",
          "ayuda": "Asumiendo gasto mensual promedio de $15,000 pesos"
        }
      ]
    }
  ],
  "versión": "2026.Diamond.V2"
