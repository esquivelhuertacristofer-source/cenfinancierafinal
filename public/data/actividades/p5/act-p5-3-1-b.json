          "ayuda": "Sin intereses, así tardas en alcanzar tu meta"
        },
        {
          "id": "total_5_anos",
          "label": "Total Ahorrado en 5 Años",
          "type": "calculated",
          "formula": "ahorro_mensual_compromiso * 60",
          "unit": "$",
          "ayuda": "5 años × 12 meses × tu aportación mensual"
        }
      ]
    }
